# Локально: export BOT_TOKEN=...  або змінна TELEGRAM_BOT_TOKEN
# Railway: Variables → BOT_TOKEN (без лапок навколо значення)
BOT_TOKEN=123456789:AA...your_token_from_BotFather

# Railway Postgres: додай DATABASE_URL (Reference з плагіна Postgres) — тоді SQLite не потрібен.
# DATABASE_URL=postgresql://...

# Лише якщо НЕМАЄ DATABASE_URL — файл SQLite (volume: SQLITE_PATH=/data/telc.sqlite)
# SQLITE_PATH=/data/telc.sqlite
